{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": [
    "before 9am on monday"
  ],
  "labels": [
    "dependencies"
  ],
  "swift": {
    "enabled": true
  },
  "github-actions": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "swift"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Swift Package Manager dependencies (non-major)"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions"
    }
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2
}
